{
  "name": "claude-code-rules",
  "version": "0.1.0",
  "description": "Claude Code rules manager - discover, install, and manage .claude/rules/ files",
  "type": "module",
  "bin": {
    "ccr": "./dist/cli.js"
  },
  "files": [
    "dist",
    "rules"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
